# ═══════════════════════════════════════════════════════════════
#  YT Summarizer Bot — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────────
# Get bot token from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here


# ── AI Provider (at least ONE required) ─────────────────────────

# 🟢 OPTION A: Groq (RECOMMENDED - free, fast, generous limits)
# Sign up free at https://console.groq.com → API Keys → Create Key
# Free tier: 30 RPM, 14,400 requests/day, uses llama-3.3-70b
GROQ_API_KEY=your-groq-api-key-here

# 🔵 OPTION B: Google Gemini
# Get key from https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1,500 requests/day
# GEMINI_API_KEY=your-gemini-api-key-here


# ── Local Telegram Bot API Server (optional) ────────────────────
# Needed when api.telegram.org is blocked on your network.
# Steps:
#   1. Get API_ID + API_HASH from https://my.telegram.org/apps
#   2. Run: docker compose up -d telegram-bot-api
#   3. Uncomment below:
#
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
# LOCAL_BOT_API_SERVER_URL=http://localhost:8081


# ── Optional tuning ─────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_CACHE_SIZE=100
CACHE_TTL_SECONDS=3600
MAX_QA_HISTORY=10
OPENCLAW_SKILL_PORT=8080
